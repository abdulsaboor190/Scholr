// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum BookStatus {
  AVAILABLE
  BORROWED
  OVERDUE
}

enum BorrowRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  RETURNED
  OVERDUE
}

enum AccountStatus {
  ACTIVE
  WARNED
  SUSPENDED
}

enum ReportTargetType {
  BOOK
  MESSAGE
  USER
}

enum ReportReason {
  MISLEADING_DESCRIPTION
  WRONG_PHOTOS
  HARASSMENT
  ITEM_NOT_RETURNED
  ITEM_DAMAGED
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum NotificationType {
  REQUEST_RECEIVED
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  NEW_MESSAGE
  DUE_SOON
  OVERDUE
  ACCOUNT_WARNING
  ACCOUNT_SUSPENDED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password      String?
  avatarUrl     String?       @map("avatar_url")
  googleId      String?       @unique @map("google_id")
  pushToken     String?       @map("push_token")
  role          Role          @default(USER)
  accountStatus AccountStatus @default(ACTIVE) @map("account_status")
  averageRating Decimal?      @map("average_rating") @db.Decimal(3, 2)
  reviewCount   Int           @default(0) @map("review_count")
  reportCount   Int           @default(0) @map("report_count")
  lastActiveAt  DateTime?     @map("last_active_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  books              Book[]
  borrowRequests     BorrowRequest[]  @relation("Requester")
  chatsAsUser1       Chat[]           @relation("User1Chats")
  chatsAsUser2       Chat[]           @relation("User2Chats")
  messages           Message[]
  notifications      Notification[]
  reviewsGiven       Review[]         @relation("ReviewerRelation")
  reviewsReceived    Review[]         @relation("RevieweeRelation")
  reports            Report[]         @relation("ReporterRelation")
  adminActions       AdminAction[]    @relation("AdminRelation")

  @@map("users")
}

model Book {
  id          String     @id @default(uuid())
  ownerId     String     @map("owner_id")
  title       String
  author      String
  subject     String
  status      BookStatus @default(AVAILABLE)
  imageUrl    String?    @map("image_url")
  reportCount Int        @default(0) @map("report_count")
  isHidden    Boolean    @default(false) @map("is_hidden")
  createdAt   DateTime   @default(now()) @map("created_at")

  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  borrowRequests BorrowRequest[]
  reviews        Review[]

  @@index([ownerId])
  @@index([subject])
  @@index([status])
  @@index([isHidden])
  @@map("books")
}

model BorrowRequest {
  id             String              @id @default(uuid())
  bookId         String              @map("book_id")
  requesterId    String              @map("requester_id")
  status         BorrowRequestStatus @default(PENDING)
  dueDate        DateTime?           @map("due_date")
  lastNotifiedAt DateTime?           @map("last_notified_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  requester User     @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  chats     Chat[]
  reviews   Review[]

  @@index([bookId])
  @@index([requesterId])
  @@index([status])
  @@map("borrow_requests")
}

model Chat {
  id          String   @id @default(uuid())
  requestId   String   @map("request_id")
  user1Id     String   @map("user1_id")
  user2Id     String   @map("user2_id")
  lastMessage String?  @map("last_message")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  request  BorrowRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user1    User          @relation("User1Chats", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User          @relation("User2Chats", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([requestId])
  @@unique([requestId, user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("chats")
}

model Message {
  id        String    @id @default(uuid())
  chatId    String    @map("chat_id")
  senderId  String    @map("sender_id")
  content   String
  isHidden  Boolean   @default(false) @map("is_hidden")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@map("messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Review {
  id            String   @id @default(uuid())
  transactionId String   @map("transaction_id")
  reviewerId    String   @map("reviewer_id")
  revieweeId    String   @map("reviewee_id")
  bookId        String   @map("book_id")
  rating        Int
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  transaction BorrowRequest @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reviewer    User          @relation("ReviewerRelation", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee    User          @relation("RevieweeRelation", fields: [revieweeId], references: [id], onDelete: Cascade)
  book        Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([transactionId, reviewerId])
  @@index([revieweeId])
  @@index([reviewerId])
  @@map("reviews")
}

model Report {
  id         String           @id @default(uuid())
  reporterId String           @map("reporter_id")
  targetType ReportTargetType @map("target_type")
  targetId   String           @map("target_id")
  reason     ReportReason
  details    String?
  status     ReportStatus     @default(PENDING)
  createdAt  DateTime         @default(now()) @map("created_at")

  reporter     User          @relation("ReporterRelation", fields: [reporterId], references: [id], onDelete: Cascade)
  adminActions AdminAction[]

  @@unique([reporterId, targetType, targetId])
  @@index([targetType, targetId, status])
  @@index([status])
  @@map("reports")
}

model AdminAction {
  id         String           @id @default(uuid())
  adminId    String           @map("admin_id")
  reportId   String?          @map("report_id")
  action     String
  targetType ReportTargetType @map("target_type")
  targetId   String           @map("target_id")
  note       String?
  createdAt  DateTime         @default(now()) @map("created_at")

  admin  User    @relation("AdminRelation", fields: [adminId], references: [id], onDelete: Cascade)
  report Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([targetType, targetId])
  @@map("admin_actions")
}
