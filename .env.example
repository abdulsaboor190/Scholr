# Database
DATABASE_URL="postgresql://postgres:saboor190@localhost:5432/bookshare?schema=public"

# JWT
JWT_ACCESS_SECRET="your-access-secret-key"
JWT_REFRESH_SECRET="your-refresh-secret-key"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# University Email Domains (comma-separated)
ALLOWED_EMAIL_DOMAINS="nu.edu.pk,isb.nu.edu.pk"
# University email local part regex (case-insensitive)
# Example: i233039@isb.nu.edu.pk (letter i/k/l/p/m + 2-digit batch + 4-digit roll)
ALLOWED_EMAIL_LOCALPART_REGEX="^[iklpm]\\d{2}\\d{4}$"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# App
PORT=3000
NODE_ENV="development"
